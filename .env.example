# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Only needed for webhook mode (not polling). Must be HTTPS.
TELEGRAM_WEBHOOK_URL=https://your-domain.example.com/webhook
# Random string; Telegram includes it in webhook requests so you can verify origin.
TELEGRAM_WEBHOOK_SECRET=change-me-to-a-random-string

# OpenAI (needed for receipt parsing + natural-language report filters)
OPENAI_API_KEY=sk-...

# Database
# Local dev (native Postgres):
#   postgresql+asyncpg://USER:PASSWORD@localhost:5432/expenses
# Docker Compose (talks to the "db" service):
#   postgresql+asyncpg://expenses:${DB_PASSWORD}@db:5432/expenses
DATABASE_URL=postgresql+asyncpg://expenses:expenses@localhost:5432/expenses
# Only used by docker-compose to set POSTGRES_PASSWORD on the db service.
DB_PASSWORD=change-me

# Email (optional — only used if you schedule email reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Expense Bot <expenses@example.com>

# Currency
BASE_CURRENCY=EUR
EXCHANGE_RATE_API_KEY=

# Storage
# Inside Docker this should be /data/receipts (see docker-compose volume).
RECEIPT_STORAGE_PATH=./receipts

# App
TIMEZONE=Europe/Madrid
# Comma-separated Telegram user IDs allowed to use the bot. Get yours from @userinfobot.
# Leave empty to allow everyone (NOT recommended — the bot calls paid OpenAI APIs).
ALLOWED_TELEGRAM_USERS=
